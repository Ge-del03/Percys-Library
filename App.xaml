<Application x:Class="ComicReader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ComicReader.Converters"
            >
    <Application.Resources>
        <ResourceDictionary>
            <!-- Probar solo ThemeTokens.xaml primero -->
            <ResourceDictionary.MergedDictionaries>
                <!-- Orden: Tokens base -> Fallback mínimo -> Estilos base -> Estilo Cómic -->
                <ResourceDictionary Source="Themes/ThemeTokens.xaml"/>
                <ResourceDictionary Source="Themes/FallbackStyles.xaml"/>
                <ResourceDictionary Source="Themes/BaseStyles.xaml"/>
                <ResourceDictionary Source="Themes/ComicStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Convertidores básicos -->
            <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
            <converters:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:IsComicViewVisibleConverter x:Key="IsComicViewVisibleConverter"/>
            
            <!-- Fondo dinámico básico -->
            <SolidColorBrush x:Key="DynamicHomeBackgroundBrush" Color="#333333"/>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>