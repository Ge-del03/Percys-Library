<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 🎨 TEMA CÓMIC - Colores Vibrantes y Efectos Dramáticos -->
    
    <!-- Colores principales estilo cómic -->
    <Color x:Key="ComicYellow">#FFD700</Color>
    <Color x:Key="ComicRed">#FF4444</Color>
    <Color x:Key="ComicBlue">#4488FF</Color>
    <Color x:Key="ComicPurple">#AA44FF</Color>
    <Color x:Key="ComicGreen">#44FF88</Color>
    
    <!-- Fondo oscuro con textura -->
    <LinearGradientBrush x:Key="ComicBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A0A0A" Offset="0"/>
        <GradientStop Color="#1A1A2E" Offset="0.5"/>
        <GradientStop Color="#0A0A0A" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Estilo de botón tipo cómic con efecto POW! -->
    <Style x:Key="ComicButtonStyle" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFD700" Offset="0"/>
                    <GradientStop Color="#FFA500" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="FontFamily" Value="Arial Black, Impact"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="5" Opacity="0.6"/>
                        </Border.Effect>
                        <ContentPresenter x:Name="contentPresenter" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover - Efecto de brillo intenso -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Effect" TargetName="border">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FFFF00" BlurRadius="25" ShadowDepth="0" Opacity="1"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFF00" Offset="0"/>
                                        <GradientStop Color="#FFD700" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Pressed - Efecto de impacto -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform" TargetName="border">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect" TargetName="border">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF0000" BlurRadius="30" ShadowDepth="0" Opacity="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Estilo de botón secundario estilo cómic -->
    <Style x:Key="ComicSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4488FF" Offset="0"/>
                    <GradientStop Color="#2244AA" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Arial Black, Impact"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4488FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter x:Name="contentPresenter" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Effect" TargetName="border">
                                <Setter.Value>
                                    <DropShadowEffect Color="#66AAFF" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#66AAFF" Offset="0"/>
                                        <GradientStop Color="#4488FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform" TargetName="border">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Panel con efecto de viñeta de cómic -->
    <Style x:Key="ComicPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#1A1A2E"/>
        <Setter Property="BorderBrush" Value="#FFD700"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Texto estilo cómic con contorno -->
    <Style x:Key="ComicTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Arial Black, Impact"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="2" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Título principal tipo cómic -->
    <Style x:Key="ComicTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Arial Black, Impact"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="Foreground">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FFD700" Offset="0"/>
                    <GradientStop Color="#FFA500" Offset="0.5"/>
                    <GradientStop Color="#FFD700" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
