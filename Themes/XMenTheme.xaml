<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema X-Men: Amarillo vibrante y azul profundo del equipo mutante -->
    <Color x:Key="BackgroundColor">#0A1628</Color>
    <Color x:Key="HeaderBackground">#FFD700</Color>
    <Color x:Key="TextColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#4A90E2</Color>
    <Color x:Key="TextDisabledColor">#6B7280</Color>
    <Color x:Key="PrimaryColor">#FFD700</Color>
    <Color x:Key="SecondaryColor">#4A90E2</Color>
    <Color x:Key="HighlightColor">#FF6B35</Color>
    <Color x:Key="FocusBorderColor">#FF6B35</Color>
    <Color x:Key="CardBackground">#1E2A3A</Color>
    <Color x:Key="FooterBackground">#4A90E2</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#0A1628"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FF6B35"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF8C42"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#E55039"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#2C3E50"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#0A1628"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#E6C200"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#4A90E2"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#357ABD"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#357ABD"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#FFD700"/>
</ResourceDictionary>