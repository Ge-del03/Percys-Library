<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Golden Age: Paleta vintage inspirada en los comics de la era dorada (1938-1956) -->
    <Color x:Key="BackgroundColor">#FFF8DC</Color>
    <Color x:Key="HeaderBackground">#8B4513</Color>
    <Color x:Key="TextColor">#2F4F4F</Color>
    <Color x:Key="TextSecondaryColor">#696969</Color>
    <Color x:Key="TextDisabledColor">#A9A9A9</Color>
    <Color x:Key="PrimaryColor">#CD853F</Color>
    <Color x:Key="SecondaryColor">#B22222</Color>
    <Color x:Key="HighlightColor">#FFD700</Color>
    <Color x:Key="FocusBorderColor">#CD853F</Color>
    <Color x:Key="CardBackground">#FFFAF0</Color>
    <Color x:Key="FooterBackground">#D2B48C</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#2F4F4F"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D2B48C"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#F5DEB3"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FFEFD5"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FF8F00"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#F5DEB3"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#D2B48C"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#CD853F"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#A0522D"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#B22222"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#8B0000"/>
    <SolidColorBrush x:Key="ButtonDangerBrush" Color="#DC143C"/>
    <SolidColorBrush x:Key="ButtonDangerTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonDangerBorderBrush" Color="#B91C3C"/>

    <!-- Tipografías del tema -->
    <FontFamily x:Key="Font.Primary">Georgia</FontFamily>
    <FontFamily x:Key="Font.Header">Georgia Bold</FontFamily>
    <FontFamily x:Key="Font.Mono">Courier New</FontFamily>
</ResourceDictionary>
