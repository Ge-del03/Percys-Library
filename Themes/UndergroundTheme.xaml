<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Underground: Colores rebeldes y contraculturales -->
    <Color x:Key="BackgroundColor">#1B1B1B</Color>
    <Color x:Key="HeaderBackground">#FF4500</Color>
    <Color x:Key="TextColor">#FFFF00</Color>
    <Color x:Key="TextSecondaryColor">#FFA500</Color>
    <Color x:Key="TextDisabledColor">#666666</Color>
    <Color x:Key="PrimaryColor">#FF4500</Color>
    <Color x:Key="SecondaryColor">#FFFF00</Color>
    <Color x:Key="HighlightColor">#FF1493</Color>
    <Color x:Key="FocusBorderColor">#FF1493</Color>
    <Color x:Key="CardBackground">#2D2D2D</Color>
    <Color x:Key="FooterBackground">#3A3A3A</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FF4500"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FF1493"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF69B4"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#DC143C"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#555555"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#FF4500"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#E6400E"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#E63E00"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#E6E600"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#E6E600"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#FF4500"/>
</ResourceDictionary>