<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Era Dorada: Colores cálidos inspirados en los cómics de los años 40-50 -->
    <Color x:Key="BackgroundColor">#2C1810</Color>
    <Color x:Key="HeaderBackground">#D4AF37</Color>
    <Color x:Key="TextColor">#F5F5DC</Color>
    <Color x:Key="TextSecondaryColor">#CD853F</Color>
    <Color x:Key="TextDisabledColor">#8B7355</Color>
    <Color x:Key="PrimaryColor">#D4AF37</Color>
    <Color x:Key="SecondaryColor">#CD853F</Color>
    <Color x:Key="HighlightColor">#FFD700</Color>
    <Color x:Key="FocusBorderColor">#FFD700</Color>
    <Color x:Key="CardBackground">#3D2914</Color>
    <Color x:Key="FooterBackground">#8B4513</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#2C1810"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#2C1810"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#8B4513"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#4A321C"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#D4AF37"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#DAA520"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#B8860B"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#4A321C"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#8B4513"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#D4AF37"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#2C1810"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#B8860B"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#DAA520"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#CD853F"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#F5F5DC"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#A0522D"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#D2691E"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#F5F5DC"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#D4AF37"/>
</ResourceDictionary>