<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Manga Moderno: Paleta monocromática con acentos de color inspirada en el manga contemporáneo -->
    <Color x:Key="BackgroundColor">#FAFAFA</Color>
    <Color x:Key="HeaderBackground">#2C2C2C</Color>
    <Color x:Key="TextColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#4A4A4A</Color>
    <Color x:Key="TextDisabledColor">#9E9E9E</Color>
    <Color x:Key="PrimaryColor">#FF6B6B</Color>
    <Color x:Key="SecondaryColor">#4ECDC4</Color>
    <Color x:Key="HighlightColor">#FFE66D</Color>
    <Color x:Key="FocusBorderColor">#FF6B6B</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="FooterBackground">#F5F5F5</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#F8F8F8"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FFE6E6"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFE66D"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFDD44"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#E0E0E0"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#4ECDC4"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#26C6DA"/>
    <SolidColorBrush x:Key="ButtonDangerBrush" Color="#F44336"/>
    <SolidColorBrush x:Key="ButtonDangerTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonDangerBorderBrush" Color="#D32F2F"/>

    <!-- Tipografías del tema -->
    <FontFamily x:Key="Font.Primary">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Header">Segoe UI Light</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas</FontFamily>
</ResourceDictionary>
