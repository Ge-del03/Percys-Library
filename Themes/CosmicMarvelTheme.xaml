<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Cosmic Marvel: Colores galácticos y cósmicos -->
    <Color x:Key="BackgroundColor">#0B0B2F</Color>
    <Color x:Key="HeaderBackground">#8A2BE2</Color>
    <Color x:Key="TextColor">#E6E6FA</Color>
    <Color x:Key="TextSecondaryColor">#C0C0FF</Color>
    <Color x:Key="TextDisabledColor">#6A6A8A</Color>
    <Color x:Key="PrimaryColor">#8A2BE2</Color>
    <Color x:Key="SecondaryColor">#FFD700</Color>
    <Color x:Key="HighlightColor">#FF00FF</Color>
    <Color x:Key="FocusBorderColor">#00BFFF</Color>
    <Color x:Key="CardBackground">#1A1A4A</Color>
    <Color x:Key="FooterBackground">#2A2A5A</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#4A4A7A"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#2A2A5A"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#8A2BE2"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FF00FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF33FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#DA70D6"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#2A2A5A"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#4A4A7A"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#8A2BE2"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#7B27CC"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#9932CC"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#0B0B2F"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#E6C200"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#FFDC00"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#E6E6FA"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#8A2BE2"/>
</ResourceDictionary>