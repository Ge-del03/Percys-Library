<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Green Lantern: Verde esmeralda y negro espacial -->
    <Color x:Key="BackgroundColor">#0F2027</Color>
    <Color x:Key="HeaderBackground">#00FF87</Color>
    <Color x:Key="TextColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#4ECDC4</Color>
    <Color x:Key="TextDisabledColor">#6B7280</Color>
    <Color x:Key="PrimaryColor">#00FF87</Color>
    <Color x:Key="SecondaryColor">#4ECDC4</Color>
    <Color x:Key="HighlightColor">#FFFF00</Color>
    <Color x:Key="FocusBorderColor">#FFFF00</Color>
    <Color x:Key="CardBackground">#1A3A3A</Color>
    <Color x:Key="FooterBackground">#00AA55</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#0F2027"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#0F2027"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#2A5555"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#2A5555"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#00FF87"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#E6E600"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#CCCC00"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#2A5555"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#2A5555"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#00FF87"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#0F2027"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#00DD77"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#00DD77"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#4ECDC4"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#0F2027"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#26A69A"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#26A69A"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#00FF87"/>
</ResourceDictionary>