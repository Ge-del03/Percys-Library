<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Cómic Indie: Colores suaves y artísticos de cómics independientes -->
    <Color x:Key="BackgroundColor">#2F1B14</Color>
    <Color x:Key="HeaderBackground">#D2691E</Color>
    <Color x:Key="TextColor">#F5DEB3</Color>
    <Color x:Key="TextSecondaryColor">#DDA0DD</Color>
    <Color x:Key="TextDisabledColor">#8B7355</Color>
    <Color x:Key="PrimaryColor">#D2691E</Color>
    <Color x:Key="SecondaryColor">#DDA0DD</Color>
    <Color x:Key="HighlightColor">#FF69B4</Color>
    <Color x:Key="FocusBorderColor">#FF69B4</Color>
    <Color x:Key="CardBackground">#40241A</Color>
    <Color x:Key="FooterBackground">#8B4513</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#F5DEB3"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#654321"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#4D2D20"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#D2691E"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FF69B4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF1493"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#DC143C"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#4D2D20"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#654321"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#D2691E"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#F5DEB3"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#B8860B"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#CD853F"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#DDA0DD"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#2F1B14"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#DA70D6"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#DA70D6"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#F5DEB3"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#DDA0DD"/>
</ResourceDictionary>