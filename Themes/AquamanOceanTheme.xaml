<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Aquaman: Azul océano profundo y verde aguamarina -->
    <Color x:Key="BackgroundColor">#001122</Color>
    <Color x:Key="HeaderBackground">#20B2AA</Color>
    <Color x:Key="TextColor">#F0FFFF</Color>
    <Color x:Key="TextSecondaryColor">#7FFFD4</Color>
    <Color x:Key="TextDisabledColor">#4682B4</Color>
    <Color x:Key="PrimaryColor">#20B2AA</Color>
    <Color x:Key="SecondaryColor">#4682B4</Color>
    <Color x:Key="HighlightColor">#FFD700</Color>
    <Color x:Key="FocusBorderColor">#FFD700</Color>
    <Color x:Key="CardBackground">#003344</Color>
    <Color x:Key="FooterBackground">#1E90FF</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#001122"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#001122"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#336699"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#004466"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#20B2AA"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFD700"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FF8F00"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#004466"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#336699"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#20B2AA"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#001122"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#17A2B8"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#17A2B8"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#4682B4"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#F0FFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#2E74B5"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#2E74B5"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#F0FFFF"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#20B2AA"/>
</ResourceDictionary>