<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Batman Nocturno: Negro profundo, gris acero y amarillo gotham -->
    <Color x:Key="BackgroundColor">#0D0D0D</Color>
    <Color x:Key="HeaderBackground">#1C1C1C</Color>
    <Color x:Key="TextColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#FFCC00</Color>
    <Color x:Key="TextDisabledColor">#6B7280</Color>
    <Color x:Key="PrimaryColor">#1C1C1C</Color>
    <Color x:Key="SecondaryColor">#FFCC00</Color>
    <Color x:Key="HighlightColor">#FFCC00</Color>
    <Color x:Key="FocusBorderColor">#FFCC00</Color>
    <Color x:Key="CardBackground">#1A1A1A</Color>
    <Color x:Key="FooterBackground">#333333</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#1C1C1C"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFCC00"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#E6B800"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#CC9900"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#333333"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#1C1C1C"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#FFCC00"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#E6B800"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#E6B800"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#FFCC00"/>
    
    <!-- Colores dinámicos para fondo del HomeView -->
    <Color x:Key="HomeBackgroundColor1">#0A0A0A</Color>
    <Color x:Key="HomeBackgroundColor2">#1C1C1C</Color>
    <Color x:Key="HomeBackgroundColor3">#2C2C2C</Color>
    <Color x:Key="HomeBackgroundColor4">#FFCC00</Color>
</ResourceDictionary>