<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Era de Plata: Colores vibrantes de los años 60-70 -->
    <Color x:Key="BackgroundColor">#1A0033</Color>
    <Color x:Key="HeaderBackground">#FF1493</Color>
    <Color x:Key="TextColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#00FFFF</Color>
    <Color x:Key="TextDisabledColor">#808080</Color>
    <Color x:Key="PrimaryColor">#FF1493</Color>
    <Color x:Key="SecondaryColor">#00FFFF</Color>
    <Color x:Key="HighlightColor">#FFFF00</Color>
    <Color x:Key="FocusBorderColor">#FFFF00</Color>
    <Color x:Key="CardBackground">#330066</Color>
    <Color x:Key="FooterBackground">#9932CC</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#1A0033"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#663399"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#4D0080"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FF1493"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#E6E600"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#CCCC00"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#4D0080"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#663399"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#FF1493"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#DC143C"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#DC143C"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#00FFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#1A0033"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#00CED1"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#00CED1"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#FF1493"/>
</ResourceDictionary>