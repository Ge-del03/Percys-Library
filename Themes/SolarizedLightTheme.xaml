<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Vintage Comic: Estilo periódico clásico con colores nostálgicos -->
    <Color x:Key="BackgroundColor">#FFFEF7</Color>
    <Color x:Key="HeaderTextColor">#FFFFFF</Color>
    <Color x:Key="PrimaryColor">#D2691E</Color>
    <Color x:Key="SecondaryColor">#CD853F</Color>
    <Color x:Key="TextColor">#2F2F2F</Color>
    <Color x:Key="TextSecondaryColor">#5D4037</Color>
    <Color x:Key="TextDisabledColor">#A1887F</Color>
    <Color x:Key="FooterBackground">#DEB887</Color>
    <Color x:Key="HeaderBackground">#8B4513</Color>
    <Color x:Key="CardBackground">#FFF8E1</Color>
    <Color x:Key="HighlightColor">#FF8C00</Color>
    <Color x:Key="FocusBorderColor">#D2691E</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="{StaticResource HeaderTextColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#CCC"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    
    <!-- Aliases para claves usadas en XAML -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#EBF4FF"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1E40AF"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#D2691E"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#A0522D"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#FFF8E1"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#2F2F2F"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#D2691E"/>
    <SolidColorBrush x:Key="ButtonDangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="ButtonDangerTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonDangerBorderBrush" Color="#991B1B"/>

    <!-- Tipografías del tema -->
    <FontFamily x:Key="Font.Primary">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Header">Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas</FontFamily>
</ResourceDictionary>