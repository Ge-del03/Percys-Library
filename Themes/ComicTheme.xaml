<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Paleta vibrante estilo cómic, con buen contraste -->
    <Color x:Key="BackgroundColor">#FFF7F2</Color>
    <Color x:Key="HeaderBackground">#FFE54D</Color>
    <Color x:Key="TextColor">#1F2937</Color>
    <Color x:Key="TextSecondaryColor">#374151</Color>
    <Color x:Key="TextDisabledColor">#9CA3AF</Color>
    <Color x:Key="PrimaryColor">#FF2D2D</Color>
    <Color x:Key="SecondaryColor">#0096FF</Color>
    <Color x:Key="HighlightColor">#111827</Color>
    <Color x:Key="FocusBorderColor">#111827</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FEF9E7"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#374151"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <!-- Tipografías del tema Comic -->
    <FontFamily x:Key="Font.Primary">"Comic Neue", "Comic Sans MS", Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Header">"Comic Neue Bold", "Comic Sans MS", Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Code</FontFamily>

    <!-- Estilos específicos del tema -->
    <Style x:Key="ThumbnailBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#1F2937"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Margin" Value="5"/>
    </Style>
    <Style x:Key="ThumbnailTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Header}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    <Style x:Key="NightModeOverlayStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="#B3000000"/>
        <Setter Property="RadiusX" Value="0"/>
        <Setter Property="RadiusY" Value="0"/>
    </Style>
    <Style x:Key="PageProgressIndicatorStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Header}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style x:Key="ErrorOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="#CCFF2D2D"/>
        <Setter Property="BorderBrush" Value="#1F2937"/>
        <Setter Property="BorderThickness" Value="4"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
    </Style>
    <Style x:Key="FooterButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#1F2937"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#0096FF"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ButtonDangerBrush" Color="#FF2D2D"/>
    <SolidColorBrush x:Key="ButtonDangerTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonDangerBorderBrush" Color="#B71C1C"/>
</ResourceDictionary>
