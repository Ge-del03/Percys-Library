<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema Manga: Colores suaves inspirados en el manga japonés -->
    <Color x:Key="BackgroundColor">#FAF8F3</Color>
    <Color x:Key="HeaderBackground">#FF69B4</Color>
    <Color x:Key="TextColor">#2B2B2B</Color>
    <Color x:Key="TextSecondaryColor">#666666</Color>
    <Color x:Key="TextDisabledColor">#AAAAAA</Color>
    <Color x:Key="PrimaryColor">#FF69B4</Color>
    <Color x:Key="SecondaryColor">#87CEEB</Color>
    <Color x:Key="HighlightColor">#FFB6C1</Color>
    <Color x:Key="FocusBorderColor">#FF1493</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="FooterBackground">#F0F0F0</Color>

    <!-- Brushes base del tema -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource FooterBackground}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextColorBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="HeaderTextColorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="PrimaryColorBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryColorBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="HighlightTextBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="AccentColorBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ItemBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#F8F8F8"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#FF69B4"/>
    <SolidColorBrush x:Key="CurrentPageBrush" Color="#FFB6C1"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF8FA3"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FF1493"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PlaceholderImageBrush" Color="#E0E0E0"/>

    <!-- Botones por tema -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#FF69B4"/>
    <SolidColorBrush x:Key="ButtonPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPrimaryBorderBrush" Color="#E652A1"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="#FF8FA3"/>
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#87CEEB"/>
    <SolidColorBrush x:Key="ButtonSecondaryTextBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorderBrush" Color="#7BC1E6"/>
    <SolidColorBrush x:Key="ButtonSecondaryHoverBrush" Color="#A4D7F0"/>

    <!-- Colores específicos del HomeView -->
    <SolidColorBrush x:Key="HomeBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="HomeTitleBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="HomeSubtitleBrush" Color="#FF69B4"/>
</ResourceDictionary>