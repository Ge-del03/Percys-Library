<Window x:Class="ComicReader.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estadísticas de Lectura - Percy's Library" 
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" 
                Background="#2d2d30" 
                Padding="20" 
                Margin="0,0,0,20"
                CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊 Estadísticas de Lectura" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock x:Name="SummaryText" 
                               Text="Cargando estadísticas..." 
                               Foreground="#999999" 
                               FontSize="13"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Actualizar" Click="RefreshButton_Click" Margin="0,0,10,0"/>
                    <Button Content="📥 Exportar" Click="ExportButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenido principal -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            
            <!-- Tab: Resumen General -->
            <TabItem Header="Resumen General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tarjetas de estadísticas principales -->
                        <UniformGrid Rows="2" Columns="4" Grid.Row="0" Margin="0,0,0,20">
                            <!-- Total de cómics leídos -->
                            <Border Background="#3498db" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalComicsText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Cómics Leídos" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Total de páginas -->
                            <Border Background="#2ecc71" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="📄" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalPagesText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Páginas Leídas" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Tiempo total -->
                            <Border Background="#e74c3c" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="⏱️" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalTimeText" 
                                               Text="0h" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Tiempo de Lectura" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Racha actual -->
                            <Border Background="#f39c12" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="🔥" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="StreakText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Días Consecutivos" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Promedio diario -->
                            <Border Background="#9b59b6" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="DailyAvgText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Páginas/Día (Promedio)" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Cómics favoritos -->
                            <Border Background="#1abc9c" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="⭐" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FavoritesText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Favoritos" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Logros desbloqueados -->
                            <Border Background="#e67e22" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="🏆" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="AchievementsText" 
                                               Text="0/25" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Logros" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>

                            <!-- Colecciones -->
                            <Border Background="#34495e" Margin="5" Padding="20" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CollectionsText" 
                                               Text="0" 
                                               Foreground="White" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Colecciones" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.8"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Gráficos -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Actividad semanal -->
                            <Border Grid.Column="0" Background="#2d2d30" Padding="20" Margin="5" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Actividad Semanal" 
                                               Foreground="White" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Margin="0,0,0,15"/>
                                    <ListBox x:Name="WeeklyActivityList" 
                                             Background="Transparent" 
                                             BorderThickness="0"
                                             Height="200"/>
                                </StackPanel>
                            </Border>

                            <!-- Formatos preferidos -->
                            <Border Grid.Column="1" Background="#2d2d30" Padding="20" Margin="5" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Formatos Preferidos" 
                                               Foreground="White" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Margin="0,0,0,15"/>
                                    <ListBox x:Name="FormatsList" 
                                             Background="Transparent" 
                                             BorderThickness="0"
                                             Height="200"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Cómics más leídos -->
                        <Border Grid.Row="2" Background="#2d2d30" Padding="20" Margin="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="🏅 Top 10 Cómics Más Leídos" 
                                           Foreground="White" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Margin="0,0,0,15"/>
                                <DataGrid x:Name="TopComicsGrid"
                                          AutoGenerateColumns="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          Height="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Width="40" Binding="{Binding Rank}"/>
                                        <DataGridTextColumn Header="Nombre" Width="*" Binding="{Binding ComicName}"/>
                                        <DataGridTextColumn Header="Veces Leído" Width="120" Binding="{Binding ReadCount}"/>
                                        <DataGridTextColumn Header="Última Lectura" Width="150" Binding="{Binding LastRead, StringFormat=dd/MM/yyyy}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Historial -->
            <TabItem Header="Historial">
                <Border Background="#2d2d30" Margin="10" Padding="20" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Filtrar por fecha:" 
                                       Foreground="White" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <DatePicker x:Name="HistoryFromDate" Width="130" Margin="0,0,10,0"/>
                            <TextBlock Text="a" 
                                       Foreground="White" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <DatePicker x:Name="HistoryToDate" Width="130" Margin="0,0,10,0"/>
                            <Button Content="Aplicar" Click="FilterHistoryButton_Click"/>
                        </StackPanel>

                        <DataGrid x:Name="HistoryGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fecha" Width="150" Binding="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}"/>
                                <DataGridTextColumn Header="Cómic" Width="*" Binding="{Binding ComicName}"/>
                                <DataGridTextColumn Header="Página" Width="80" Binding="{Binding PageNumber}"/>
                                <DataGridTextColumn Header="Duración" Width="100" Binding="{Binding Duration}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Tab: Objetivos -->
            <TabItem Header="Objetivos">
                <Border Background="#2d2d30" Margin="10" Padding="20" CornerRadius="8">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="📈 Mis Objetivos de Lectura" 
                                       Foreground="White" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,20"/>

                            <!-- Objetivo diario -->
                            <Border Background="#3498db" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Objetivo Diario: 20 páginas" 
                                               Foreground="White" 
                                               FontSize="14" 
                                               FontWeight="Bold"/>
                                    <ProgressBar x:Name="DailyGoalProgress" 
                                                 Height="20" 
                                                 Margin="0,10,0,0" 
                                                 Minimum="0" 
                                                 Maximum="100" 
                                                 Value="65"
                                                 Foreground="#2ecc71"/>
                                    <TextBlock Text="13/20 páginas (65%)" 
                                               Foreground="White" 
                                               FontSize="12" 
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Objetivo semanal -->
                            <Border Background="#2ecc71" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Objetivo Semanal: 5 cómics" 
                                               Foreground="White" 
                                               FontSize="14" 
                                               FontWeight="Bold"/>
                                    <ProgressBar x:Name="WeeklyGoalProgress" 
                                                 Height="20" 
                                                 Margin="0,10,0,0" 
                                                 Minimum="0" 
                                                 Maximum="100" 
                                                 Value="40"
                                                 Foreground="#3498db"/>
                                    <TextBlock Text="2/5 cómics (40%)" 
                                               Foreground="White" 
                                               FontSize="12" 
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Objetivo mensual -->
                            <Border Background="#e74c3c" Padding="15" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Objetivo Mensual: 20 cómics" 
                                               Foreground="White" 
                                               FontSize="14" 
                                               FontWeight="Bold"/>
                                    <ProgressBar x:Name="MonthlyGoalProgress" 
                                                 Height="20" 
                                                 Margin="0,10,0,0" 
                                                 Minimum="0" 
                                                 Maximum="100" 
                                                 Value="75"
                                                 Foreground="#f39c12"/>
                                    <TextBlock Text="15/20 cómics (75%)" 
                                               Foreground="White" 
                                               FontSize="12" 
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
