<Window x:Class="ComicReader.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📤 Exportar Páginas" 
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Exportar Páginas del Cómic" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,20"/>

        <!-- Opciones de exportación -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Rango de páginas -->
                <GroupBox Header="Rango de Páginas" Foreground="White" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="AllPagesRadio" Content="Todas las páginas" Foreground="White" 
                                     IsChecked="True" Margin="0,5"/>
                        <RadioButton x:Name="CurrentPageRadio" Content="Página actual solamente" Foreground="White" 
                                     Margin="0,5"/>
                        <RadioButton x:Name="RangeRadio" Content="Rango personalizado:" Foreground="White" 
                                     Margin="0,5"/>
                        <Grid Margin="20,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Desde:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="StartPageTextBox" Grid.Column="1" Text="1" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Hasta:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="EndPageTextBox" Grid.Column="3" Text="1"/>
                        </Grid>
                        <RadioButton x:Name="SelectedPagesRadio" Content="Páginas seleccionadas" Foreground="White" 
                                     Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <!-- Formato de salida -->
                <GroupBox Header="Formato de Salida" Foreground="White" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <ComboBox x:Name="FormatComboBox" SelectedIndex="0" SelectionChanged="Format_Changed">
                            <ComboBoxItem Content="PNG (mejor calidad, mayor tamaño)" Tag="PNG"/>
                            <ComboBoxItem Content="JPEG (buena calidad, menor tamaño)" Tag="JPEG"/>
                            <ComboBoxItem Content="WebP (excelente compresión)" Tag="WebP"/>
                        </ComboBox>

                        <!-- Control de calidad (solo para JPEG/WebP) -->
                        <Grid x:Name="QualityPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Calidad:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider x:Name="QualitySlider" Grid.Column="1" Minimum="50" Maximum="100" Value="90" 
                                    TickFrequency="10" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="2" Text="{Binding ElementName=QualitySlider, Path=Value, StringFormat={}{0:F0}%}" 
                                       Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="40"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Redimensionamiento -->
                <GroupBox Header="Redimensionamiento" Foreground="White" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="ResizeCheckBox" Content="Redimensionar imágenes" Foreground="White" 
                                  Margin="0,5" Checked="Resize_Changed" Unchecked="Resize_Changed"/>
                        <Grid x:Name="ResizePanel" Margin="20,5,0,0" IsEnabled="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ancho máx:" Foreground="White" 
                                       VerticalAlignment="Center" Margin="0,0,10,5"/>
                            <TextBox x:Name="MaxWidthTextBox" Grid.Row="0" Grid.Column="1" Text="1920" Margin="0,0,10,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Alto máx:" Foreground="White" 
                                       VerticalAlignment="Center" Margin="0,0,10,5"/>
                            <TextBox x:Name="MaxHeightTextBox" Grid.Row="0" Grid.Column="3" Text="1080" Margin="0,0,0,5"/>

                            <CheckBox x:Name="MaintainAspectCheckBox" Grid.Row="1" Grid.ColumnSpan="4" 
                                      Content="Mantener proporción" Foreground="White" IsChecked="True" Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Carpeta de destino -->
                <GroupBox Header="Carpeta de Destino" Foreground="White">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputFolderTextBox" Grid.Column="0" IsReadOnly="True" 
                                 Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Examinar..." Width="100" Click="BrowseFolder_Click"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Estimación de tamaño -->
        <Border Grid.Row="2" Background="#2d2d30" CornerRadius="5" Padding="15" Margin="0,15,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#cccccc" FontSize="12">
                        <Run Text="Páginas a exportar:"/>
                        <Run x:Name="PageCountText" Text="0" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Foreground="#cccccc" FontSize="12" Margin="0,5,0,0">
                        <Run Text="Tamaño estimado:"/>
                        <Run x:Name="EstimatedSizeText" Text="Calculando..." FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Content="↻ Calcular" Width="100" Height="30" 
                        Style="{StaticResource ModernButtonStyle}" Click="Calculate_Click"/>
            </Grid>
        </Border>

        <!-- Botones de acción -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Barra de progreso -->
            <StackPanel Grid.Column="0" x:Name="ProgressPanel" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="ProgressText" Text="Exportando..." Foreground="White" Margin="0,0,0,5"/>
                <ProgressBar x:Name="ProgressBar" Height="10" Minimum="0" Maximum="100"/>
            </StackPanel>

            <!-- Botones -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ExportButton" Content="📤 Exportar" Width="120" Height="40" 
                        Margin="0,0,10,0" Style="{StaticResource AccentButtonStyle}" 
                        Click="Export_Click"/>
                <Button Content="Cancelar" Width="100" Height="40" 
                        Style="{StaticResource ModernButtonStyle}" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
