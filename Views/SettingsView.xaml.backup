                                        </UniformGrid>

                                        <!-- TERCERA ALTERNATIVA: Botón para revertir tema -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
                                            <Button Content="🔄 Revertir Tema" Click="RevertTheme_Click" 
                                                    Padding="12,6" 
                                                    Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                                                    Background="{DynamicResource ButtonSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                                    ToolTip="Deshace los cambios de tema y vuelve al tema guardado"/>
                                        </StackPanel>

                                        <WrapPanel Margin="0,10,0,0">
                                            <CheckBox Content="Modo nocturno" IsChecked="{Binding IsNightMode, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Mostrar número de página" IsChecked="{Binding ShowPageNumberOverlay, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Mostrar barra de progreso" IsChecked="{Binding ShowPageProgressIndicator, Mode=TwoWay}" Margin="0,0,12,8"/>
                                        </WrapPanel>

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Brillo" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <Slider Minimum="0.5" Maximum="1.5" SmallChange="0.05" LargeChange="0.1" Value="{Binding Brightness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Margin="16,16,0,0" FontWeight="SemiBold" Text="{Binding Brightness, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextBrush}"/>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Contraste" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <Slider Minimum="0.5" Maximum="1.5" SmallChange="0.05" LargeChange="0.1" Value="{Binding Contrast, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Margin="16,16,0,0" FontWeight="SemiBold" Text="{Binding Contrast, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextBrush}"/>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                            <Button Content="Restablecer apariencia" Click="ResetAppearance_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Fondos del Menú">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Fondos del Menú Principal" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Elige entre 30 fondos épicos inspirados en héroes de Marvel, DC y cómics clásicos para personalizar tu pantalla de inicio." Style="{StaticResource SettingsSectionDescription}"/>
                                        
                                        <UniformGrid Columns="3">
                                            <!-- Héroes DC Clásicos -->
