                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Venom Symbiote" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Negro siniestro magenta" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>

                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HomeBackground}" Value="PhoenixHomeBackground">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#8B0000" Offset="0"/>
                                                                <GradientStop Color="#FF4500" Offset="0.35"/>
                                                                <GradientStop Color="#FFD700" Offset="0.7"/>
                                                                <GradientStop Color="#FF6347" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Phoenix Force" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Fuego cósmico ardiente" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>

                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HomeBackground}" Value="SinestroHomeBackground">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#4B0082" Offset="0"/>
                                                                <GradientStop Color="#FFD700" Offset="0.35"/>
                                                                <GradientStop Color="#FFFF00" Offset="0.7"/>
                                                                <GradientStop Color="#FFA500" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Sinestro Corps" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Miedo amarillo dorado" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>

                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HomeBackground}" Value="BronzeAgeHomeBackground">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#8B4513" Offset="0"/>
                                                                <GradientStop Color="#CD853F" Offset="0.35"/>
                                                                <GradientStop Color="#DAA520" Offset="0.7"/>
                                                                <GradientStop Color="#B8860B" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Bronze Age" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Era de bronce vintage" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>

                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HomeBackground}" Value="ModernAgeHomeBackground">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#111827" Offset="0"/>
                                                                <GradientStop Color="#1E40AF" Offset="0.35"/>
                                                                <GradientStop Color="#06B6D4" Offset="0.7"/>
                                                                <GradientStop Color="#10B981" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Modern Age" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Era moderna tech" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- ¡Fondos adicionales completados hasta llegar a 30! -->
                                            
                                        </UniformGrid>
                                        
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
                                            <TextBlock Text="🦸‍♂️ ¡30 Fondos Épicos Completos! Superman, Batman, Spiderman, Avengers y más..." 
                                                       FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,10">
                                            <Button Content="🔄 Restablecer a Fondo por Defecto" Click="ResetHomeBackground_Click" 
                                                    Padding="12,6" 
                                                    Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                                                    Background="{DynamicResource ButtonSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                                    ToolTip="Volver al fondo azul clásico por defecto"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Animaciones">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Animaciones" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Controla la experiencia visual y ajusta la suavidad de las transiciones." Style="{StaticResource SettingsSectionDescription}"/>
                                        <WrapPanel>
                                            <CheckBox Content="Habilitar animaciones de la interfaz" IsChecked="{Binding EnableAnimations, Mode=TwoWay}" Margin="0,0,16,10"/>
                                            <CheckBox Content="Reducir movimiento" IsChecked="{Binding PreferReducedMotion, Mode=TwoWay}" Margin="0,0,16,10"/>
                                            <CheckBox Content="Animar paso de página" IsChecked="{Binding EnablePageTurnAnimations, Mode=TwoWay}" Margin="0,0,16,10"/>
                                            <CheckBox Content="Fundido en pantalla completa" IsChecked="{Binding FadeOnFullscreenTransitions, Mode=TwoWay}" Margin="0,0,16,10"/>
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                                            <TextBlock Text="Estilo de transición:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,0"/>
                                            <ComboBox Width="220" SelectedValuePath="Tag" SelectedValue="{Binding PageTurnAnimationStyle, Mode=TwoWay}">
                                                <ComboBoxItem Content="Deslizante" Tag="Slide"/>
                                                <ComboBoxItem Content="Fundido" Tag="Fade"/>
                                                <ComboBoxItem Content="Voltear" Tag="Flip"/>
                                                <ComboBoxItem Content="Sin animación" Tag="None"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Duración del giro de página" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <Slider Minimum="60" Maximum="600" TickFrequency="30" IsSnapToTickEnabled="True" Value="{Binding PageTurnAnimationDurationMs, Mode=TwoWay}" IsEnabled="{Binding EnablePageTurnAnimations}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Margin="16,16,0,0" FontWeight="SemiBold" Text="{Binding PageTurnAnimationDurationMs, StringFormat={}{0} ms}" Foreground="{DynamicResource TextBrush}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                            <Button Content="Restablecer animaciones" Click="ResetAnimations_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Pantalla completa">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Pantalla completa e inmersivo" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Controla cómo se oculta la interfaz y el cursor durante la lectura inmersiva." Style="{StaticResource SettingsSectionDescription}"/>
                                        <WrapPanel>
                                            <CheckBox Content="Entrar en modo inmersivo al abrir" IsChecked="{Binding AutoEnterImmersiveOnOpen, Mode=TwoWay}" Margin="0,0,16,10"/>
                                            <CheckBox Content="Ocultar overlay solo en inmersivo" IsChecked="{Binding HideOverlayOnlyInImmersive, Mode=TwoWay}" Margin="0,0,16,10"/>
                                        </WrapPanel>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Ocultar overlay tras" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Name="HideOverlayDelayBox"
                                                         Width="56"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding HideOverlayDelaySeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewTextInput="SV_NumericOnly_PreviewTextInput"
                                                         DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                                <TextBlock Text="seg" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="24,0,0,0">
                                                <TextBlock Text="Ocultar cursor tras" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Name="HideCursorDelayBox"
                                                         Width="56"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding HideCursorDelaySeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewTextInput="SV_NumericOnly_PreviewTextInput"
                                                         DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                                <TextBlock Text="seg" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                            <Button Content="Valores recomendados" Click="ResetFullscreenSettings_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Herramientas y respaldo">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Herramientas y respaldo" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Exporta tus preferencias, importa copias de seguridad o restaura los valores originales." Style="{StaticResource SettingsSectionDescription}"/>
                                        <WrapPanel>
                                            <Button Content="Restaurar valores predeterminados" Margin="0,0,12,12" Click="ResetDefaults_Click"/>
                                            <Button Content="Exportar configuración" Margin="0,0,12,12" Click="ExportSettings_Click"/>
                                            <Button Content="Importar configuración" Margin="0,0,12,12" Click="ImportSettings_Click"/>
                                            <Button Content="Limpiar 'Seguir leyendo'" Margin="0,0,12,12" Click="ClearHistory_Click"/>
                                        </WrapPanel>
                                        <TextBlock Text="La exportación genera un archivo XML que puedes compartir o respaldar."
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="PDF">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="PDF" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Controla la calidad del renderizado para archivos PDF." Style="{StaticResource SettingsSectionDescription}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="Ancho de render (px)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBox Width="90" Text="{Binding PdfRenderWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="SV_NumericOnly_PreviewTextInput" DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Alto de render (px)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBox Width="90" Text="{Binding PdfRenderHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="SV_NumericOnly_PreviewTextInput" DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="DPI (modo legado)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Width="90" Text="{Binding PdfRenderDpi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="SV_NumericOnly_PreviewTextInput" DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                        </StackPanel>
                                        <Button Content="Aplicar y re-renderizar PDF actual" Margin="0,16,0,0" Click="ApplyPdfRender_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Estadísticas">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}" Margin="0,14,0,40">
                                    <StackPanel>
                                        <TextBlock Text="Estadísticas de lectura" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Un vistazo rápido a tu tiempo de lectura." Style="{StaticResource SettingsSectionDescription}"/>
                                        <UniformGrid Columns="2" Margin="0,4,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Tiempo total" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Statistics.TotalReadingTime}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Páginas leídas" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Statistics.PagesRead}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
