                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF6B6B" Offset="0"/>
                                                                <GradientStop Color="#FFD166" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Cómic" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Colores vivos inspirados en viñetas impresas." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="Sepia" Click="ThemeCard_Click">
