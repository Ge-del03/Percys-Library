                                                </StackPanel>
                                            </Button>
                                            <Button Tag="CosmicMarvel" Click="ThemeCard_Click">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Theme}" Value="CosmicMarvel">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
