<UserControl x:Class="ComicReader.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Gradientes cósmicos mejorados -->
        <LinearGradientBrush x:Key="CosmicHeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8A2BE2" Offset="0"/>
            <GradientStop Color="#9932CC" Offset="0.5"/>
            <GradientStop Color="#8B008B" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="CosmicCardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1A4A" Offset="0"/>
            <GradientStop Color="#2A2A5A" Offset="0.7"/>
            <GradientStop Color="#1A1A4A" Offset="1"/>
        </LinearGradientBrush>
        
        <RadialGradientBrush x:Key="CosmicGlowBrush">
            <GradientStop Color="#44FF00FF" Offset="0"/>
            <GradientStop Color="#22FF00FF" Offset="0.7"/>
            <GradientStop Color="#00FF00FF" Offset="1"/>
        </RadialGradientBrush>
        
        <!-- Efectos de sombra cósmica -->
        <DropShadowEffect x:Key="CosmicGlow" Color="#8A2BE2" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="20" ShadowDepth="8" Opacity="0.4"/>
        <DropShadowEffect x:Key="TextGlow" Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
        
        <Thickness x:Key="SettingsCardMargin">0,16,0,0</Thickness>
        
        <!-- Estilo mejorado para tarjetas de sección -->
        <Style x:Key="SettingsSectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CosmicCardGradient}"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8A2BE2" Offset="0"/>
                        <GradientStop Color="#FF00FF" Offset="0.5"/>
                        <GradientStop Color="#8A2BE2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Margin" Value="{StaticResource SettingsCardMargin}"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FF00FF" BlurRadius="25" ShadowDepth="8" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF00FF" Offset="0"/>
                                <GradientStop Color="#FFD700" Offset="0.5"/>
                                <GradientStop Color="#FF00FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Estilos de texto cósmicos mejorados -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E6E6FA" Offset="0"/>
                        <GradientStop Color="#FFD700" Offset="0.7"/>
                        <GradientStop Color="#E6E6FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect" Value="{StaticResource TextGlow}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>
        
        <Style x:Key="SettingsSectionDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#C0C0FF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,16"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        
        <!-- Estilo para títulos principales con efecto cósmico -->
        <Style x:Key="CosmicTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FF00FF" Offset="0.5"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2" BlurRadius="20" ShadowDepth="0" Opacity="1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Estilo mejorado para tarjetas de tema con efectos cósmicos -->
        <Style x:Key="ThemeCardStyle" TargetType="Button">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{StaticResource CosmicCardGradient}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="16"
                                Padding="16"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="CardEffect" Color="#000000" BlurRadius="12" ShadowDepth="6" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF00FF" Offset="0"/>
                                            <GradientStop Color="#FFD700" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Card" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="CardEffect" Property="Color" Value="#8A2BE2"/>
                                <Setter TargetName="CardEffect" Property="BlurRadius" Value="20"/>
                                <Setter TargetName="CardEffect" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="Card" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2A2A5A" Offset="0"/>
                                            <GradientStop Color="#3A3A6A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Card" Property="Opacity" Value="0.9"/>
                                <Setter TargetName="Card" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Estilo futurista para botones de navegación -->
        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="SettingsSections"/>
            <Setter Property="Foreground" Value="#E6E6FA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="NavEffect" Color="#000000" BlurRadius="8" ShadowDepth="3" Opacity="0"/>
                            </Border.Effect>
                            <Grid>
                                <!-- Barra de acento lateral -->
                                <Rectangle x:Name="AccentBar" 
                                          Width="4" 
                                          Height="24"
                                          HorizontalAlignment="Left" 
                                          VerticalAlignment="Center"
                                          Margin="6,0,0,0"
                                          RadiusX="2" RadiusY="2"
                                          Fill="Transparent"/>
                                <ContentPresenter Margin="20,12" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#22FF00FF" Offset="0"/>
                                            <GradientStop Color="#11FF00FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="AccentBar" Property="Fill" Value="#FF00FF"/>
                                <Setter TargetName="NavEffect" Property="Color" Value="#8A2BE2"/>
                                <Setter TargetName="NavEffect" Property="Opacity" Value="0.4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8A2BE2" Offset="0"/>
                                            <GradientStop Color="#9932CC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="AccentBar" Property="Fill" Value="#FFD700"/>
                                <Setter TargetName="NavEffect" Property="Color" Value="#FFD700"/>
                                <Setter TargetName="NavEffect" Property="BlurRadius" Value="15"/>
                                <Setter TargetName="NavEffect" Property="Opacity" Value="0.8"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NoHeaderTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <!-- Estilo mejorado para chips de resumen -->
        <Style x:Key="SummaryChip" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2A5A" Offset="0"/>
                        <GradientStop Color="#3A3A6A" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#8A2BE2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8A2BE2" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Contenedor principal adaptable -->
    <Grid Background="Transparent">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Panel de navegación mejorado -->
            <Border Background="{StaticResource CosmicHeaderGradient}"
                    CornerRadius="20"
                    Padding="24"
                    Margin="0,0,24,0">
                <Border.Effect>
                    <DropShadowEffect Color="#8A2BE2" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <!-- Título principal con efecto cósmico -->
                    <TextBlock Text="⚙️ CONFIGURACIÓN"
                               Style="{StaticResource CosmicTitle}"
                               TextAlignment="Center"
                               Margin="0,0,0,8"/>
                    <Rectangle Height="2" 
                              RadiusX="1" RadiusY="1"
                              Margin="20,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#FF00FF" Offset="0.5"/>
                                <GradientStop Color="#FFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="🚀 Personaliza tu experiencia galáctica de lectura"
                               Foreground="#FFFFFF"
                               FontSize="14"
                               FontStyle="Italic"
                               Margin="0,12,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Opacity="0.9"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,8">
                    <StackPanel>
                        <RadioButton x:Name="NavSummary" Content="Resumen y accesos" Tag="0" Style="{StaticResource NavRadioButtonStyle}" IsChecked="True" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavReading" Content="Lectura rápida" Tag="1" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavAppearance" Content="Apariencia y tema" Tag="2" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavHomeBackgrounds" Content="🎨 Fondos del Menú" Tag="3" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavAnimations" Content="Animaciones" Tag="4" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavFullscreen" Content="Pantalla completa" Tag="5" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavPerformance" Content="Rendimiento y caché" Tag="6" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavTools" Content="Herramientas y respaldo" Tag="7" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavPdf" Content="PDF" Tag="8" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                        <RadioButton x:Name="NavStats" Content="Estadísticas" Tag="9" Style="{StaticResource NavRadioButtonStyle}" Checked="SectionNav_Checked"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,24,0,0">
                    <TextBlock Text="🔥 ACCIONES CÓSMICAS"
                               Foreground="#FFD700"
                               FontWeight="Bold"
                               FontSize="16"
                               TextAlignment="Center"
                               Margin="0,0,0,16">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,0,0">
                        <Button Content="💾 Guardar" Click="SaveNow_Click" 
                                Background="#0078D4" Foreground="White"
                                Padding="12,6" Margin="0,0,8,0" BorderThickness="0"/>
                        <Button Content="🔄 Restablecer" Click="ResetDefaults_Click"
                                Background="White" Foreground="Black" BorderBrush="#E0E0E0"
                                Padding="12,6" BorderThickness="1"/>
                    </StackPanel>
                    
                    <Button Content="🎯 GUARDAR CAMBIOS"
                            Margin="0,0,0,8"
                            Style="{StaticResource PrimaryButtonStyle}"
                            FontWeight="Bold"
                            Click="SaveNow_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#8A2BE2" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                        </Button.Effect>
                    </Button>
                    
                    <Button Content="📚 Guía Galáctica"
                            Margin="0,0,0,8"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OpenCustomizationGuide_Click"/>
                    
                    <Button Content="🔄 Resetear Cosmos"
                            Margin="0,0,0,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="ResetDefaults_Click"/>
                </StackPanel>
            </Grid>
        </Border>

            <!-- Panel principal de contenido mejorado -->
            <Border Grid.Column="1"
                    Background="{StaticResource CosmicCardGradient}"
                    CornerRadius="20"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tarjeta de resumen cósmica mejorada -->
                <Border x:Name="SummaryCard"
                        Grid.Row="0"
                        Background="{StaticResource CosmicHeaderGradient}"
                        CornerRadius="18"
                        Padding="24"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF00FF" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="🌟" FontSize="24" Margin="0,0,8,0"/>
                            <TextBlock Text="PANEL CÓSMICO DE CONTROL"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FFD700">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="🌟" FontSize="24" Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <Rectangle Height="1" 
                                  Margin="40,0,40,16"
                                  Fill="#FFD700" 
                                  Opacity="0.7"/>
                        
                        <TextBlock Text="🚀 Accede a configuraciones galácticas avanzadas para optimizar tu experiencia de lectura intergaláctica."
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   Margin="0,0,0,16"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <WrapPanel>
                            <Border Style="{StaticResource SummaryChip}">
                                <StackPanel>
                                    <TextBlock Text="Tema activo" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding Theme}" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Margin="0,6,0,0">
                                        <Run Text="Modo nocturno: "/>
                                        <Run>
                                            <Run.Style>
                                                <Style TargetType="Run">
                                                    <Setter Property="Text" Value="Desactivado"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNightMode}" Value="True">
                                                            <Setter Property="Text" Value="Activado"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Run.Style>
                                        </Run>
                                    </TextBlock>
                                    <Button Content="Vista previa de temas"
                                            Margin="0,10,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenCustomizationGuide_Click"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryChip}">
                                <StackPanel>
                                    <TextBlock Text="Lectura" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Margin="0,6,0,0">
                                        <Run Text="Dirección: "/>
                                        <Run Text="{Binding CurrentReadingDirection}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Avance auto: "/>
                                        <Run>
                                            <Run.Style>
                                                <Style TargetType="Run">
                                                    <Setter Property="Text" Value="Desactivado"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutoAdvancePages}" Value="True">
                                                            <Setter Property="Text" Value="Activado"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Run.Style>
                                        </Run>
                                    </TextBlock>
                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Modo inmersivo al abrir: "/>
                                        <Run>
                                            <Run.Style>
                                                <Style TargetType="Run">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutoEnterImmersiveOnOpen}" Value="True">
                                                            <Setter Property="Text" Value="Sí"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Run.Style>
                                        </Run>
                                    </TextBlock>
                                    <Button Content="Recomendaciones de lectura"
                                            Margin="0,10,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ResetReadingBasics_Click"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SummaryChip}">
                                <StackPanel>
                                    <TextBlock Text="Estadísticas" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding Statistics.TotalReadingTime}"/>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Páginas leídas: "/>
                                        <Run Text="{Binding Statistics.PagesRead}"/>
                                    </TextBlock>
                                    <ProgressBar Minimum="0.5" Maximum="1.5" Value="{Binding Brightness}" Height="6" Margin="0,12,0,0"/>
                                    <TextBlock Text="Brillo relativo" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <TabControl x:Name="SectionTabs"
                            Grid.Row="1"
                            SelectionChanged="SectionTabs_SelectionChanged"
                            Style="{StaticResource NoHeaderTabControlStyle}">
                    <TabItem Header="Resumen y accesos">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Preferencias generales" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Activa las opciones generales más usadas y sincroniza tus sesiones." Style="{StaticResource SettingsSectionDescription}"/>
                                        <WrapPanel>
                                            <CheckBox Content="Recordar última sesión" IsChecked="{Binding RememberLastSession, Mode=TwoWay}" Margin="0,0,18,10"/>
                                            <CheckBox Content="Mostrar miniaturas" IsChecked="{Binding ThumbnailsVisible, Mode=TwoWay}" Margin="0,0,18,10"/>
                                            <CheckBox Content="Modo lectura sin distracciones" IsChecked="{Binding IsReadingMode, Mode=TwoWay}" Margin="0,0,18,10"/>
                                            <CheckBox Content="Mostrar indicador de progreso" IsChecked="{Binding ShowPageProgressIndicator, Mode=TwoWay}" Margin="0,0,18,10"/>
                                            <CheckBox Content="Vista de recientes en lista" IsChecked="{Binding IsRecentListView, Mode=TwoWay}" Margin="0,0,18,10"/>
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="Recomendado" Click="ResetReadingBasics_Click"/>
                                            <Button Content="Guardar ahora" Margin="12,0,0,0" Click="SaveNow_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Consejos rápidos" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Aprende a sacar más partido al lector: controla accesos directos, personaliza la experiencia y mantén tu progreso." Style="{StaticResource SettingsSectionDescription}"/>
                                        <TextBlock Text="• Pulsa F para entrar o salir del modo sin distracciones." Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• Usa Shift + R para reanudar el cómic más reciente." Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• Ajusta el brillo y contraste desde Apariencia para sesiones nocturnas." Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Lectura rápida">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Preferencias de lectura" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Activa los modos rápidos y controla el comportamiento básico del lector." Style="{StaticResource SettingsSectionDescription}"/>
                                        <UniformGrid Columns="2" Rows="0" Margin="0,0,0,10">
                                            <CheckBox Content="Modo lectura sin distracciones" IsChecked="{Binding IsReadingMode, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Recordar última sesión" IsChecked="{Binding RememberLastSession, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Mostrar miniaturas en la biblioteca" IsChecked="{Binding ThumbnailsVisible, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Barra espaciadora pasa de página" IsChecked="{Binding SpacebarNextPage, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Invertir rueda del ratón" IsChecked="{Binding InvertScrollWheel, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Activar zoom con arrastre" IsChecked="{Binding EnableZoomPan, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Mostrar indicador de progreso" IsChecked="{Binding ShowPageProgressIndicator, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Mostrar indicadores de carga" IsChecked="{Binding ShowLoadingIndicators, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Ajustar página al abrir" IsChecked="{Binding AutoFitOnLoad, Mode=TwoWay}" Margin="0,0,12,8"/>
                                            <CheckBox Content="Vista compacta en 'Seguir leyendo'" IsChecked="{Binding ContinueCompactMode, Mode=TwoWay}" Margin="0,0,12,8"/>
                                        </UniformGrid>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Modo de ajuste predeterminado:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,0"/>
                                            <ComboBox Width="220"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding DefaultFitMode, Mode=TwoWay}">
                                                <ComboBoxItem Content="Ajustar al ancho" Tag="Width"/>
                                                <ComboBoxItem Content="Ajustar al alto" Tag="Height"/>
                                                <ComboBoxItem Content="Ajustar a la pantalla" Tag="Screen"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <CheckBox Content="Avance automático de páginas" IsChecked="{Binding AutoAdvancePages, Mode=TwoWay}"/>
                                            <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="cada" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBox Name="AutoAdvanceIntervalBox"
                                                         Width="56"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding AutoAdvanceInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewTextInput="SV_NumericOnly_PreviewTextInput"
                                                         DataObject.Pasting="SV_NumericOnly_Pasting"/>
                                                <TextBlock Text="segundos" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox Content="Reiniciar al llegar a la última página" IsChecked="{Binding AutoAdvanceLoop, Mode=TwoWay}" Margin="0,6,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <CheckBox Content="Habilitar modo scroll continuo" IsChecked="{Binding EnableContinuousScroll, Mode=TwoWay}"/>
                                            <CheckBox Content="Desplazamiento suave" IsChecked="{Binding SmoothScrolling, Mode=TwoWay}" Margin="18,0,0,0"/>
                                        </StackPanel>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Paso de desplazamiento" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <Slider Minimum="0.1"
                                                        Maximum="1.0"
                                                        LargeChange="0.1"
                                                        SmallChange="0.05"
                                                        IsSnapToTickEnabled="True"
                                                        TickFrequency="0.05"
                                                        Value="{Binding PageScrollStepRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="16,16,0,0"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding PageScrollStepRatio, StringFormat={}{0:P0}}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="Restablecer lectura" Click="ResetReadingBasics_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Apariencia y tema">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <Border Style="{StaticResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="Apariencia y tema" Style="{StaticResource SettingsSectionHeader}"/>
                                        <TextBlock Text="Explora temas listos para usar y ajusta la visualización de las páginas." Style="{StaticResource SettingsSectionDescription}"/>
                                        <UniformGrid Columns="3">
                                            <Button Tag="Dark" Click="ThemeCard_Click">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Theme}" Value="Dark">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#0F172A" Offset="0"/>
                                                                <GradientStop Color="#1E293B" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Oscuro" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Tema equilibrado para entornos nocturnos." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="Light" Click="ThemeCard_Click">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Theme}" Value="Light">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10" Background="#F3F4F6"/>
                                                    <TextBlock Text="Claro" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="Colores neutros que combinan con espacios luminosos." FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Tag="Comic" Click="ThemeCard_Click">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource ThemeCardStyle}" TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Theme}" Value="Comic">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
