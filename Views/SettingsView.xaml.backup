                                                <StackPanel>
                                                    <Border Height="60" CornerRadius="10">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#0B0B2F" Offset="0"/>
                                                                <GradientStop Color="#8A2BE2" Offset="0.5"/>
                                                                <GradientStop Color="#FFD700" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="Cosmic Marvel" Margin="0,8,0,0" FontWeight="SemiBold" HorizontalAlignment="Left"/>
