<Window x:Class="ComicReader.Views.AnnotationEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de Anotaciones" 
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de herramientas -->
        <Border Grid.Row="0" Background="#2d2d30" Padding="10" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TextAnnotationBtn" Content="📝 Texto" Width="80" Height="35" Margin="5,0" 
                        Style="{StaticResource ModernButtonStyle}" Click="TextAnnotation_Click"/>
                <Button x:Name="HighlightBtn" Content="🖍️ Resaltar" Width="100" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Highlight_Click"/>
                <Button x:Name="ArrowBtn" Content="➡️ Flecha" Width="90" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Arrow_Click"/>
                <Button x:Name="DrawBtn" Content="✏️ Dibujar" Width="90" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Draw_Click"/>
                <Button x:Name="RectangleBtn" Content="⬜ Rectángulo" Width="110" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Rectangle_Click"/>
                <Button x:Name="CircleBtn" Content="⭕ Círculo" Width="90" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Circle_Click"/>
                
                <Separator Width="1" Margin="10,5" Background="#3f3f46"/>
                
                <ComboBox x:Name="ColorPicker" Width="100" Height="30" Margin="5,0" SelectedIndex="0">
                    <ComboBoxItem Content="🟡 Amarillo" Tag="#FFFF00"/>
                    <ComboBoxItem Content="🔴 Rojo" Tag="#FF0000"/>
                    <ComboBoxItem Content="🔵 Azul" Tag="#0000FF"/>
                    <ComboBoxItem Content="🟢 Verde" Tag="#00FF00"/>
                    <ComboBoxItem Content="🟠 Naranja" Tag="#FFA500"/>
                    <ComboBoxItem Content="🟣 Morado" Tag="#800080"/>
                </ComboBox>
                
                <Button x:Name="DeleteBtn" Content="🗑️ Eliminar" Width="90" Height="35" Margin="5,0"
                        Style="{StaticResource DangerButtonStyle}" Click="Delete_Click"/>
            </StackPanel>
        </Border>

        <!-- Área de trabajo -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas con la página del cómic -->
            <Border Grid.Column="0" Background="#252526" Margin="10">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="AnnotationCanvas" Background="Transparent">
                        <Image x:Name="PageImage" Stretch="Uniform"/>
                    </Canvas>
                </ScrollViewer>
            </Border>

            <!-- Panel de anotaciones -->
            <Border Grid.Column="1" Background="#2d2d30" Margin="0,10,10,10" BorderBrush="#3f3f46" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Anotaciones en esta página" Foreground="White" 
                               FontSize="14" FontWeight="Bold" Margin="10" />

                    <ListBox x:Name="AnnotationsList" Grid.Row="1" Background="#1e1e1e" 
                             BorderThickness="0" Foreground="White" Margin="10,0"
                             SelectionChanged="AnnotationsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2d2d30" Padding="10" Margin="0,5" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Type}" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding TextContent}" Foreground="#cccccc" 
                                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                                   Visibility="{Binding TextContent, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        <TextBlock Text="{Binding CreatedDate, StringFormat='dd/MM/yyyy HH:mm'}" 
                                                   Foreground="#888888" FontSize="10" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Barra de estado -->
        <Border Grid.Row="2" Background="#2d2d30" Padding="10" BorderBrush="#3f3f46" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusText" Text="Selecciona una herramienta para comenzar" 
                           Foreground="#cccccc" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Guardar" Width="100" Height="35" Margin="5,0"
                            Style="{StaticResource AccentButtonStyle}" Click="Save_Click"/>
                    <Button Content="Cancelar" Width="100" Height="35" Margin="5,0"
                            Style="{StaticResource ModernButtonStyle}" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
