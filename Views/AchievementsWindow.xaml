<Window x:Class="ComicReader.Views.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏆 Logros" 
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado con estadísticas -->
        <Border Grid.Row="0" Background="#2d2d30" Padding="20" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏆 Tus Logros" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Text="Sigue leyendo para desbloquear más logros" 
                               FontSize="14" Foreground="#cccccc" Margin="0,5,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#3498db" CornerRadius="10" Padding="15" Margin="10,0">
                    <StackPanel>
                        <TextBlock Text="Puntos Totales" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalPointsText" Text="0" FontSize="28" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#9b59b6" CornerRadius="10" Padding="15" Margin="10,0">
                    <StackPanel>
                        <TextBlock Text="Desbloqueados" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="UnlockedCountText" Text="0/0" FontSize="28" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#e74c3c" CornerRadius="10" Padding="15" Margin="10,0">
                    <StackPanel>
                        <TextBlock Text="Progreso" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CompletionText" Text="0%" FontSize="28" FontWeight="Bold" 
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Barra de filtros -->
        <Border Grid.Row="1" Background="#252526" Padding="15" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtrar por:" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                
                <Button x:Name="AllBtn" Content="Todos" Width="100" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Filter_Click" Tag="All"/>
                <Button x:Name="UnlockedBtn" Content="🔓 Desbloqueados" Width="150" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Filter_Click" Tag="Unlocked"/>
                <Button x:Name="LockedBtn" Content="🔒 Bloqueados" Width="130" Height="35" Margin="5,0"
                        Style="{StaticResource ModernButtonStyle}" Click="Filter_Click" Tag="Locked"/>
                
                <Separator Width="1" Margin="15,5" Background="#3f3f46"/>
                
                <TextBlock Text="Categoría:" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CategoryFilter" Width="150" Height="30" SelectionChanged="CategoryFilter_Changed">
                    <ComboBoxItem Content="Todas" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="📖 Lectura" Tag="Reading"/>
                    <ComboBoxItem Content="📚 Colección" Tag="Collection"/>
                    <ComboBoxItem Content="🗂️ Organización" Tag="Organization"/>
                    <ComboBoxItem Content="🔍 Exploración" Tag="Exploration"/>
                    <ComboBoxItem Content="⏱️ Tiempo" Tag="Time"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Lista de logros -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#1e1e1e">
            <ItemsControl x:Name="AchievementsList" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2d2d30" CornerRadius="10" Margin="0,0,0,15" Padding="20"
                                BorderBrush="#3f3f46" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icono -->
                                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40" 
                                        Background="#3498db" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding IconEmoji}" FontSize="40" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Información -->
                                <StackPanel Grid.Column="1" Margin="20,0">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" 
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding Description}" FontSize="14" 
                                               Foreground="#cccccc" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    
                                    <!-- Progreso -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <ProgressBar Grid.Column="0" Height="8" Value="{Binding Progress}" 
                                                     Maximum="1" Foreground="#3498db" Background="#3f3f46"/>
                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Foreground="#888888" FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="CurrentValue"/>
                                                    <Binding Path="TargetValue"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                    
                                    <!-- Fecha de desbloqueo -->
                                    <TextBlock Text="{Binding UnlockedDate, StringFormat='Desbloqueado: {0:dd/MM/yyyy HH:mm}'}" 
                                               FontSize="12" Foreground="#888888" Margin="0,5,0,0"
                                               Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>

                                <!-- Puntos y estado -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                    <Border Background="#f39c12" CornerRadius="5" Padding="10,5">
                                        <TextBlock Text="{Binding Points, StringFormat='+{0} pts'}" 
                                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    
                                    <Border Margin="0,10,0,0" Background="#27ae60" CornerRadius="5" Padding="10,5"
                                            Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="✓ Desbloqueado" FontSize="12" Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    
                                    <Border Margin="0,10,0,0" Background="#7f8c8d" CornerRadius="5" Padding="10,5"
                                            Visibility="{Binding IsUnlocked, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="🔒 Bloqueado" FontSize="12" Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
