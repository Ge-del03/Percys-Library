<UserControl x:Class="ComicReader.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Estilos simples sin referencias problemáticas -->
        <Style x:Key="SimpleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF222831">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30">
                
                <!-- Header -->
                <TextBlock Text="⚙️ Configuración de ComicReader" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="#FFD369"
                          Margin="0,0,0,40"/>

                <!-- Sección de Temas -->
                <Border Background="#2A2A2A" CornerRadius="8" Padding="25" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="🎨 Temas y Apariencias" 
                                  FontSize="20" 
                                  FontWeight="Bold"
                                  Foreground="White" 
                                  Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Selecciona un tema para cambiar la apariencia de toda la aplicación:" 
                                  FontSize="14"
                                  Foreground="#D1D5DB" 
                                  Margin="0,0,0,25"/>
                        
                        <!-- Grid de temas principales -->
                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <!-- Tema Oscuro -->
                            <Button Tag="DarkTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10">
                                <StackPanel>
                                    <Rectangle Fill="#2D2D30" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="🌙 Tema Oscuro" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Tema Claro -->
                            <Button Tag="LightTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10" Background="#F8FAFC">
                                <StackPanel>
                                    <Rectangle Fill="LightGray" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="☀️ Tema Claro" Foreground="Black" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Tema Azul -->
                            <Button Tag="BlueTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10" Background="#1E40AF">
                                <StackPanel>
                                    <Rectangle Fill="#3B82F6" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="💙 Tema Azul" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Tema Verde -->
                            <Button Tag="GreenTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10" Background="#059669">
                                <StackPanel>
                                    <Rectangle Fill="#10B981" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="💚 Tema Verde" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Tema Rojo -->
                            <Button Tag="RedTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10" Background="#DC2626">
                                <StackPanel>
                                    <Rectangle Fill="#EF4444" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="❤️ Tema Rojo" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Tema Morado -->
                            <Button Tag="PurpleTheme" Click="ThemeCard_Click" Style="{StaticResource SimpleButtonStyle}" 
                                    Width="200" Height="100" Margin="10" Background="#7C3AED">
                                <StackPanel>
                                    <Rectangle Fill="#8B5CF6" Width="120" Height="50" RadiusX="5" RadiusY="5" Margin="0,0,0,10"/>
                                    <TextBlock Text="💜 Tema Morado" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Sección de Configuración Rápida -->
                <Border Background="#2A2A2A" CornerRadius="8" Padding="25" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="⚡ Configuración Rápida" 
                                  FontSize="20" 
                                  FontWeight="Bold"
                                  Foreground="White" 
                                  Margin="0,0,0,20"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="💾 Guardar Configuración" Click="SaveNow_Click" Style="{StaticResource SimpleButtonStyle}" Width="200" Margin="10,0"/>
                            <Button Content="🗑️ Limpiar Historial" Click="ClearHistory_Click" Style="{StaticResource SimpleButtonStyle}" Width="200" Margin="10,0"/>
                            <Button Content="📖 Abrir Guía" Click="OpenCustomizationGuide_Click" Style="{StaticResource SimpleButtonStyle}" Width="200" Margin="10,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mensaje de estado -->
                <Border Background="#1F2937" CornerRadius="8" Padding="20">
                    <TextBlock Text="💡 Los cambios de tema se aplican inmediatamente y se guardan automáticamente. Las estadísticas se preservan al cambiar temas." 
                              FontSize="14"
                              Foreground="#9CA3AF" 
                              TextWrapping="Wrap"
                              HorizontalAlignment="Center"/>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>