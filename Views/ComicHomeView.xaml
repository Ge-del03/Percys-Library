<UserControl x:Class="ComicReader.Views.ComicHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <!-- Animación de entrada -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource ComicBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Título principal tipo cómic -->
        <Border Grid.Row="0" Padding="40,30">
            <StackPanel>
                <TextBlock Text="PERCY'S LIBRARY" 
                           Style="{StaticResource ComicTitleStyle}"
                           HorizontalAlignment="Center"
                           FontSize="48"/>
                <TextBlock Text="¡TU COLECCIÓN DE AVENTURAS ÉPICAS!" 
                           Style="{StaticResource ComicTextStyle}"
                           HorizontalAlignment="Center"
                           FontSize="18"
                           Margin="0,10,0,0"
                           Foreground="#FFD700"/>
            </StackPanel>
        </Border>
        
        <!-- Contenido principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,20">
                
                <!-- Sección: Continuar Leyendo -->
                <Border Style="{StaticResource ComicPanelStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="⚡ CONTINUAR LEYENDO" 
                                   Style="{StaticResource ComicTextStyle}"
                                   FontSize="28"
                                   Margin="0,0,0,20"/>
                        
                        <ItemsControl x:Name="ContinueReadingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ComicButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,15"
                                            Click="ContinueReading_Click"
                                            Tag="{Binding Path}">
                                        <Button.Content>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Portada -->
                                                <Border Grid.Column="0" Width="100" Height="140" 
                                                        CornerRadius="8" Margin="0,0,20,0"
                                                        Background="#1A1A2E">
                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                                </Border>
                                                
                                                <!-- Información -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="20" FontWeight="Black"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Progress}" 
                                                               FontSize="14" FontWeight="Bold"
                                                               Margin="0,5,0,0"
                                                               Foreground="#FFD700"/>
                                                </StackPanel>
                                                
                                                <!-- Icono -->
                                                <TextBlock Grid.Column="2" Text="▶" 
                                                           FontSize="40" FontWeight="Black"
                                                           VerticalAlignment="Center"
                                                           Margin="20,0,0,0"/>
                                            </Grid>
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Mensaje si no hay nada -->
                        <TextBlock x:Name="NoContinueMessage" 
                                   Text="No hay cómics en progreso. ¡Abre uno nuevo!" 
                                   FontSize="16" FontStyle="Italic"
                                   Foreground="#888"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
                
                <!-- Sección: Recientes -->
                <Border Style="{StaticResource ComicPanelStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="🕒 RECIENTES" 
                                       Style="{StaticResource ComicTextStyle}"
                                       FontSize="28"
                                       HorizontalAlignment="Left"/>
                            <Button Content="VER TODO ➜" 
                                    Style="{StaticResource ComicSecondaryButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Click="ViewAllRecent_Click"/>
                        </Grid>
                        
                        <!-- Grid de portadas -->
                        <ItemsControl x:Name="RecentComicsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="OpenRecent_Click" 
                                            Tag="{Binding Path}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" 
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="#FFD700"
                                                        BorderThickness="3"
                                                        CornerRadius="10"
                                                        Padding="5">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="15" 
                                                                          ShadowDepth="5" Opacity="0.7"/>
                                                    </Border.Effect>
                                                    <StackPanel Width="180">
                                                        <!-- Portada -->
                                                        <Border Width="170" Height="240" 
                                                                CornerRadius="8"
                                                                Background="#1A1A2E">
                                                            <Image Source="{Binding CoverImage}" 
                                                                   Stretch="UniformToFill"/>
                                                        </Border>
                                                        <!-- Título -->
                                                        <TextBlock Text="{Binding Title}" 
                                                                   FontSize="14" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   Margin="0,10,0,0"
                                                                   MaxHeight="60"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Effect" TargetName="border">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#FFD700" 
                                                                                  BlurRadius="25" 
                                                                                  ShadowDepth="0" 
                                                                                  Opacity="1"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="RenderTransform" TargetName="border">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <!-- Sección: Acciones Rápidas -->
                <Border Style="{StaticResource ComicPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="🚀 ACCIONES RÁPIDAS" 
                                   Style="{StaticResource ComicTextStyle}"
                                   FontSize="28"
                                   Margin="0,0,0,20"/>
                        
                        <WrapPanel HorizontalAlignment="Center">
                            <Button Content="📂 ABRIR CÓMIC" 
                                    Style="{StaticResource ComicButtonStyle}"
                                    Click="OpenComic_Click"
                                    Margin="10"/>
                            <Button Content="📁 ABRIR CARPETA" 
                                    Style="{StaticResource ComicButtonStyle}"
                                    Click="OpenFolder_Click"
                                    Margin="10"/>
                            <Button Content="🔍 BUSCAR" 
                                    Style="{StaticResource ComicSecondaryButtonStyle}"
                                    Click="Search_Click"
                                    Margin="10"/>
                            <Button Content="⚙️ CONFIGURACIÓN" 
                                    Style="{StaticResource ComicSecondaryButtonStyle}"
                                    Click="Settings_Click"
                                    Margin="10"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
    </Grid>
</UserControl>
