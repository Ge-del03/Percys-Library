<Window x:Class="ComicReader.Views.CollectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📚 Colecciones" 
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: Lista de colecciones -->
        <Border Grid.Column="0" Background="#2d2d30" BorderBrush="#3f3f46" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Encabezado -->
                <Border Grid.Row="0" Background="#252526" Padding="15" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Mis Colecciones" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <Button Content="+" Width="30" Height="30" FontSize="18" FontWeight="Bold"
                                HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"
                                Click="NewCollection_Click" ToolTip="Nueva Colección"/>
                    </Grid>
                </Border>

                <!-- Lista de colecciones -->
                <ListBox x:Name="CollectionsList" Grid.Row="1" Background="#2d2d30" 
                         BorderThickness="0" Foreground="White" Padding="10"
                         SelectionChanged="CollectionsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" CornerRadius="5" Padding="15" Margin="0,5"
                                    BorderBrush="#3f3f46" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Indicador de color -->
                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,10,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Border.Background>
                                    </Border>

                                    <!-- Nombre y contador -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" 
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="#888888" FontSize="12" Margin="0,3,0,0">
                                            <Run Text="{Binding ComicCount, Mode=OneWay}"/>
                                            <Run Text="cómics"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Menú -->
                                    <Button Grid.Column="2" Content="⋮" Width="30" Height="30" FontSize="16"
                                            Style="{StaticResource ModernButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Editar" Click="EditCollection_Click"/>
                                                <MenuItem Header="Eliminar" Click="DeleteCollection_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Estadísticas -->
                <Border Grid.Row="2" Background="#252526" Padding="15" BorderBrush="#3f3f46" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Foreground="#888888" FontSize="12">
                            <Run Text="Total:"/>
                            <Run x:Name="TotalCollectionsText" Text="0" FontWeight="Bold"/>
                            <Run Text="colecciones"/>
                        </TextBlock>
                        <TextBlock Foreground="#888888" FontSize="12" Margin="0,5,0,0">
                            <Run Text="Cómics:"/>
                            <Run x:Name="TotalComicsText" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Panel derecho: Detalles de colección -->
        <Grid Grid.Column="1" Background="#1e1e1e">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado de colección seleccionada -->
            <Border Grid.Row="0" Background="#2d2d30" Padding="20" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid x:Name="CollectionHeader" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="CollectionNameText" Text="Colección" FontSize="24" FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock x:Name="CollectionDescriptionText" Text="Descripción de la colección" 
                                       FontSize="14" Foreground="#cccccc" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="➕ Agregar Cómics" Width="150" Height="40" Margin="10,0"
                                    Style="{StaticResource AccentButtonStyle}" Click="AddComics_Click"/>
                            <Button Content="▶️ Leer Primero" Width="130" Height="40" Margin="10,0"
                                    Style="{StaticResource ModernButtonStyle}" Click="ReadFirst_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Mensaje cuando no hay selección -->
                    <TextBlock x:Name="NoSelectionMessage" Text="Selecciona una colección para ver sus cómics" 
                               FontSize="16" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Grid de cómics -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ComicGrid" Margin="20">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="150" Height="230" Margin="10" Background="#2d2d30" 
                                    CornerRadius="10" Cursor="Hand" MouseLeftButtonDown="Comic_Click">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Portada -->
                                    <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Nombre -->
                                    <Border Grid.Row="1" Padding="10">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" 
                                                   TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="40"/>
                                    </Border>

                                    <!-- Botón eliminar -->
                                    <Button Grid.Row="0" Content="✕" Width="25" Height="25" FontSize="12"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5"
                                            Style="{StaticResource DangerButtonStyle}" Opacity="0.8"
                                            Click="RemoveComic_Click" Tag="{Binding Path}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
